# Variables de entorno requeridas para el Collector v0.1 AI-CTO

# 1. Base de datos origen (ODS - solo lectura)
# Usar el rol: ai_cto_collector_ro
ODS_SOURCE_DATABASE_URL="postgresql://ai_cto_collector_ro:<password>@postgres-staging-do-user-34470794-0.k.db.ondigitalocean.com:25060/defaultdb?sslmode=require"

# 2. Base de datos destino (AI-CTO - lectura/escritura)
# Usar el rol: ai_cto_app (o el que corresponda para la BD de AI-CTO)
AI_CTO_DATABASE_URL="postgresql://ai_cto_app:<password>@<host>:25060/defaultdb?sslmode=require"

# 3. Configuración del Collector
AI_CTO_TIMEZONE="Europe/Madrid"

# 4. Modo Dry-Run (true para probar logs sin insertar, false para producción/inserts reales)
AI_CTO_COLLECTOR_DRY_RUN="true"
